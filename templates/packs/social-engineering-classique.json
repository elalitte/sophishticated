    {
      "name": "Vérification identité Crédit Agricole",
      "description": "Faux mail de banque demandant une vérification DSP2 - très réaliste",
      "subject": "Crédit Agricole - Vérification obligatoire de votre identité (DSP2)",
      "sender_name": "Crédit Agricole - Service Clients",
