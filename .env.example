# =============================================================
# Sophishticated — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================

# ── Microsoft Graph API (required for sending emails) ────────
# Create an App Registration in Azure AD with Mail.ReadWrite
# and Mail.Send application permissions.
CLIENT_ID=your-azure-client-id
CLIENT_SECRET=your-azure-client-secret
TENANT_ID=your-azure-tenant-id

# ── Application ──────────────────────────────────────────────
APP_NAME="Sophishticated"
APP_ENV=production
APP_DEBUG=false
# The public URL where the app is accessible (used for tracking links)
APP_URL=http://localhost:8443
APP_PORT=8443

# ── Database ─────────────────────────────────────────────────
# When using Docker Compose, DB_HOST must match the service name
DB_HOST=db
DB_PORT=3306
DB_DATABASE=sophishticated
DB_USERNAME=root
DB_PASSWORD=secret

# ── Sessions ─────────────────────────────────────────────────
SESSION_LIFETIME=7200

# ── WebSocket ────────────────────────────────────────────────
# When using Docker Compose, WEBSOCKET_HOST must match the service name
WEBSOCKET_HOST=websocket
WEBSOCKET_PORT=8081
